{
  "name": "@maximilien-ai/workflows",
  "version": "0.1.0",
  "private": true,
  "description": "Validation and CI tooling for WORKFLOW.md specifications.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "./setup.sh",
    "format": "./format.sh",
